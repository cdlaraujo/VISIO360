{
  "name": "visio360",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^23.1.2",
    "peerjs": "^1.5.2",
    "polygon-clipping": "^0.15.3",
    "splaytree": "^3.0.1",
    "three": "0.151.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.visio360.app",
    "productName": "VISIO360",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
